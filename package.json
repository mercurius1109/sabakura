{
  "name": "survival_craft",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:bg": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-server.ps1 start",
    "dev:stop": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-server.ps1 stop",
    "dev:status": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-server.ps1 status",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.7"
  }
}
